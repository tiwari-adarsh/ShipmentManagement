<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShipmentTracker</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ShipmentApp.styles.css" asp-append-version="true" />
    ﻿
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (Context.Session.GetString("UserEmail") != null)
    {
        <!-- ══ SIDEBAR ══ -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="logo-icon">⚓</div>
                <span class="logo-name">AquaFreight</span>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section-label">Main</div>

                <a asp-controller="Dashboard" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2 nav-icon"></i>
                    <span>Dashboard</span>
                </a>

                <a asp-controller="Shipment" asp-action="Create"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Shipment" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")">
                    <i class="bi bi-clipboard-plus nav-icon"></i>
                    <span>Shipment Booking</span>
                </a>

                <div class="nav-section-label">Masters</div>

                <a asp-controller="Ship" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ship" ? "active" : "")">
                    <i class="bi bi-tsunami nav-icon"></i>
                    <span>Ship Master</span>
                </a>

                <a asp-controller="Customer" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")">
                    <i class="bi bi-people nav-icon"></i>
                    <span>Customer Master</span>
                </a>

                <div class="nav-section-label">Operations</div>

                <a asp-controller="Shipment" asp-action="Index"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Shipment" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="bi bi-box-seam nav-icon"></i>
                    <span>Shipment List</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">
                    </div>
                    <div class="user-details">
                        <div class="user-name">Admin</div>
                    <div class="user-role">email</div> 
                    </div>
                </div>
            </div>
        </aside>

        <header class="topbar">
            <button class="sidebar-toggle" onclick="toggleSidebar()">
                <i class="bi bi-list"></i>
            </button>
            <span class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>
            <div class="topbar-actions">
                <button class="topbar-btn" title="Notifications">
                    <i class="bi bi-bell"></i>
                    <span class="notif-dot"></span>
                </button>
                <button class="topbar-btn" title="Settings">
                    <i class="bi bi-gear"></i>
                </button>
                <div class="topbar-divider"></div>
                <form asp-controller="Account" asp-action="Logout"
                      method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </button>
                </form>
            </div>
        </header>

        <!-- ══ MAIN CONTENT ══ -->
        <main class="main-content">
            @* Breadcrumb *@
            @if (ViewData["FormTitle"] != null)
            {
                <nav class="breadcrumb-nav" aria-label="breadcrumb">
                    @Html.Raw(ViewData["FormTitle"]?.ToString())
                </nav>
            }

            @* Alert Messages *@
            @if (TempData["Success"] != null)
            {
                <div class="alert-toast alert-success-toast">
                    <i class="bi bi-check-circle-fill"></i>
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-toast alert-error-toast">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @TempData["Error"]
                </div>
            }

            @RenderBody()
        </main>
    }
    else
    {
        @RenderBody()
    }

    <!-- Scripts -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>