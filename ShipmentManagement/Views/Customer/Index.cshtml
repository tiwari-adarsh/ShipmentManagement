@model ShipmentManagement.ViewModels.Customer.CustomerListViewModel
@{
    ViewData["Title"] = "Customer Master";
    ViewData["Breadcrumb"] = @"
        <a href='/Dashboard'>Home</a>
        <span class='bc-sep'>›</span>
        <span class='bc-current'>Customer Master</span>
    ";
}

<div class="page-header">
    <div>
        <div class="page-title">Customer Master</div>
        <div class="page-sub">Manage all client accounts — @Model.TotalCustomers total customers</div>
    </div>
    <a asp-action="Create" class="btn-primary-custom">
        <i class="bi bi-person-plus"></i> Add Customer
    </a>
</div>

<div class="table-card page-fade">
    <div class="table-toolbar">
        <span class="table-toolbar-title">Customer Registry</span>
        <form method="get" asp-action="Index"
              style="display:flex;gap:8px;align-items:center;">
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="search" value="@Model.SearchTerm" class="search-input" placeholder="Search customers..." />
            </div>
            <button type="submit" class="btn-secondary-custom">
                <i class="bi bi-funnel"></i> Search
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn-secondary-custom">
                    <i class="bi bi-x"></i> Clear
                </a>
            }
        </form>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Code</th>
                    <th>Customer Name</th>
                    <th>Company</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>City</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Customers.Any())
                {
                    <tr>
                        <td colspan="8" style="text-align:center;padding:40px;color:var(--text-muted)">
                            <i class="bi bi-people" style="font-size:32px;display:block;margin-bottom:10px"></i>
                            No customers found.
                            <a asp-action="Create" style="color:var(--amber)">Add your first customer</a>
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    @foreach (var c in Model.Customers)
                    {
                        <tr>
                            <td style="color:var(--text-muted)">@i</td>
                            <td><span class="td-mono">@c.CustomerCode</span></td>
                            <td><b>@c.CustomerName</b></td>
                            <td>@c.CompanyName</td>
                            <td style="font-size:12px">@c.Email</td>
                            <td style="font-size:12px">@c.Phone</td>
                            <td>@c.City</td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn-edit">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@c.Id"
                                          method="post" style="display:inline"
                                          onsubmit="return confirm('Delete @c.CustomerName?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-delete">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="pagination-wrap">
        <span class="pag-info">
            Showing @Model.Customers.Count of @Model.TotalCustomers customers
        </span>
    </div>
</div>